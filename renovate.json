{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "assignees": ["JonahMMay"],
  "labels": ["renovate"],
  "configMigration": true,
  "forkProcessing": "enabled",
  "packageRules": [
    {
      "groupName": "PyTorch",
      "description": "Group the coupled torch ecosystem into one PR (torch and torch-tensorrt must move together). Match by package name; matchSourceUrls relied on PyPI source metadata and split them into separate PRs.",
      "automerge": true,
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "matchPackageNames": ["torch", "torch-tensorrt", "torchvision", "torchaudio"]
    },
    {
      "automerge": true,
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"]
    }
  ]
}
